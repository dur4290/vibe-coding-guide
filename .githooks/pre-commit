#!/bin/sh
# 보안 검사 Python 스크립트 실행 (Windows / Mac / Linux 공통)
DIR="$(dirname "$0")"

if command -v python3 >/dev/null 2>&1; then
    exec python3 "$DIR/pre-commit.py"
elif command -v python >/dev/null 2>&1; then
    exec python "$DIR/pre-commit.py"
else
    echo ""
    echo "⚠️  Python을 찾을 수 없어요."
    echo "   Python을 설치하면 보안 검사가 자동으로 활성화됩니다."
    echo "   설치 주소: https://www.python.org/downloads/"
    echo ""
    exit 1
fi
